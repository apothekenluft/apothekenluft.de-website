---
import BlogLayout from '../layouts/Blog.astro';

const postModules = import.meta.glob('./posts/*.md', { eager: true });
const postRawFiles = import.meta.glob('./posts/*.md', {
  eager: true,
  query: '?raw',
  import: 'default',
});

function createTeaser(markdown: string, maxLength = 220) {
  const text = markdown
    .replace(/^---[\s\S]*?---/, '')
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[`*_>#]/g, ' ')
    .replace(/\|/g, ' ')
    .replace(/^-{3,}$/gm, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  if (text.length <= maxLength) {
    return text;
  }

  return text.slice(0, maxLength).trim() + '...';
}

const allPosts = Object.entries(postModules)
  .map(([path, post]: [string, any]) => ({
    ...post,
    teaser: createTeaser((postRawFiles[path] as string) || ''),
  }))
  .sort(
    (a: any, b: any) =>
      new Date(b.frontmatter?.date ?? 0).getTime() -
      new Date(a.frontmatter?.date ?? 0).getTime()
  );
---
<BlogLayout title="Blog">
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12">
    <header class="mb-8 sm:mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        Blog apothekenluft.de
      </h1>
      <p class="mt-3 max-w-2xl text-base text-gray-700 sm:text-lg">
        Hier finden Sie Beiträge rund um die Apothekenwelt, kompakt vorgestellt und direkt zum Weiterlesen verlinkt.
      </p>
    </header>

    <ul role="list" class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
      {allPosts.map((post: any) => (
        <li>
          <article class="group grid aspect-square overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition duration-200 hover:shadow-md">
            <a href={post.url} class="grid h-full grid-rows-[44%_1fr]">
              {post.frontmatter?.coverImage ? (
                <img
                  src={post.frontmatter.coverImage}
                  alt={post.frontmatter?.title}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="h-full w-full bg-gray-100" aria-hidden="true"></div>
              )}

              <div class="flex h-full flex-col p-4 sm:p-5">
                <div class="min-h-[5.25rem] sm:min-h-[5.75rem]">
                  <h2 class="line-clamp-3 text-lg font-semibold leading-tight text-gray-900 sm:text-xl">
                    {post.frontmatter?.title}
                  </h2>
                </div>

                <p class="mt-3 line-clamp-4 text-sm leading-6 text-gray-700 sm:text-base">
                  {post.teaser}
                </p>

                <div class="mt-auto pt-4">
                  <span class="inline-flex items-center text-sm font-medium text-sky-700 transition group-hover:text-sky-800">
                    Weiterlesen...
                  </span>
                </div>
              </div>
            </a>
          </article>
        </li>
      ))}
    </ul>
  </section>
</BlogLayout>