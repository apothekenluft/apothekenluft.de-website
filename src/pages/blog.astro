---
import BlogLayout from '../layouts/Blog.astro';

const allPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true }))
  .sort((a: any, b: any) => new Date(b.frontmatter?.date ?? 0).getTime() - new Date(a.frontmatter?.date ?? 0).getTime())
  .map((post: any) => {
    const raw = String(post.compiledContent?.() ?? post.rawContent?.() ?? '').replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
    const teaser = raw.length > 180 ? `${raw.slice(0, 177).trim()}...` : raw;
    return { ...post, teaser };
  });
---
<BlogLayout title="Blog">
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12">
    <header class="mb-8 sm:mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Blog apothekenluft.de</h1>
      <p class="mt-3 max-w-2xl text-base text-gray-700 sm:text-lg">Hier finden Sie Beiträge rund um die Apothekenwelt, kompakt vorgestellt und direkt zum Weiterlesen verlinkt.</p>
    </header>

    <ul role="list" class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
      {allPosts.map((post: any) => (
        <li>
          <article class="group grid aspect-square overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition duration-200 hover:shadow-md">
            <a href={post.url} class="grid h-full grid-rows-[44%_1fr]">
              {post.frontmatter?.coverImage ? (
                <img
                  src={post.frontmatter.coverImage}
                  alt={post.frontmatter?.title}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="h-full w-full bg-gray-100" aria-hidden="true"></div>
              )}

              <div class="flex h-full flex-col p-4 sm:p-5">
                <h2 class="line-clamp-3 text-lg font-semibold leading-tight text-gray-900 sm:text-xl">{post.frontmatter?.title}</h2>
                <p class="mt-3 line-clamp-5 text-sm leading-6 text-gray-700 sm:text-base">{post.teaser}</p>
                <div class="mt-auto pt-4">
                  <span class="inline-flex items-center text-sm font-medium text-sky-700 transition group-hover:text-sky-800">
                    Weiterlesen...
                  </span>
                </div>
              </div>
            </a>
          </article>
        </li>
      ))}
    </ul>
  </section>
</BlogLayout>
