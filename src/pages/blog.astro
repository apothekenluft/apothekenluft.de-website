---
import BlogLayout from '../layouts/Blog.astro';

const postModules = import.meta.glob('./posts/*.md', { eager: true });
const postRawFiles = import.meta.glob('./posts/*.md', {
  eager: true,
  query: '?raw',
  import: 'default',
});

function createTeaser(markdown: string, maxLength = 300) {
  const text = markdown
    .replace(/^---[\s\S]*?---/, '')
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[`*_>#]/g, ' ')
    .replace(/\|/g, ' ')
    .replace(/^-{3,}$/gm, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  if (text.length <= maxLength) {
    return text;
  }

  return text.slice(0, maxLength).trimEnd() + '…';
}

function formatDate(value?: string | Date) {
  if (!value) return '';
  return new Intl.DateTimeFormat('de-DE', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  }).format(new Date(value));
}

const allPosts = Object.entries(postModules)
  .map(([path, post]: [string, any]) => ({
    ...post,
    teaser: createTeaser((postRawFiles[path] as string) || ''),
    formattedDate: formatDate(post.frontmatter?.date),
  }))
  .sort(
    (a: any, b: any) =>
      new Date(b.frontmatter?.date ?? 0).getTime() -
      new Date(a.frontmatter?.date ?? 0).getTime()
  );
---

<BlogLayout title="Blog">
  <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-10 lg:px-8 lg:py-12">
    <header class="mb-8 sm:mb-10">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        Blog apothekenluft.de
      </h1>
      <p class="mt-3 max-w-3xl text-base text-gray-700 sm:text-lg">
        Hier finden Sie alle Beiträge in einer übersichtlichen Kacheldarstellung.
      </p>
    </header>

    <ul
      id="post-grid"
      role="list"
      class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6"
    >
      {allPosts.map((post: any, index: number) => (
        <li
          class:list={[
            "post-card-item",
            index >= 9 && "is-hidden",
          ]}
        >
          <a
            href={post.url}
            class="group flex h-full flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-600 focus-visible:ring-offset-2"
          >
            {post.frontmatter?.coverImage ? (
              <div class="aspect-square overflow-hidden bg-gray-100">
                <img
                  src={post.frontmatter.coverImage}
                  alt={post.frontmatter?.title}
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ) : (
              <div class="aspect-square bg-gray-100" aria-hidden="true"></div>
            )}

            <article class="flex flex-1 flex-col p-5">
              <header class="mb-4 flex items-start justify-between gap-4">
                <h2 class="text-xl font-bold leading-tight text-gray-900">
                  {post.frontmatter?.title}
                </h2>
                <p class="shrink-0 text-right text-xs font-medium uppercase tracking-wide text-gray-500">
                  {post.formattedDate}
                </p>
              </header>

              <p class="text-sm leading-6 text-gray-700">
                {post.teaser}
              </p>
            </article>
          </a>
        </li>
      ))}
    </ul>

    <div
      id="post-grid-sentinel"
      class="mt-8 flex justify-center"
      aria-hidden="true"
    >
      <span class="text-sm text-gray-400">Weitere Beiträge werden geladen …</span>
    </div>
  </section>

  <script>
    const hiddenClass = 'is-hidden';
    const batchSize = 6;
    const cards = Array.from(document.querySelectorAll('.post-card-item'));
    const sentinel = document.getElementById('post-grid-sentinel');

    let visibleCount = cards.filter((card) => !card.classList.contains(hiddenClass)).length;

    const revealNextBatch = () => {
      const nextCards = cards.slice(visibleCount, visibleCount + batchSize);
      nextCards.forEach((card) => card.classList.remove(hiddenClass));
      visibleCount += nextCards.length;

      if (visibleCount >= cards.length && sentinel) {
        sentinel.remove();
        observer.disconnect();
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            revealNextBatch();
          }
        });
      },
      {
        rootMargin: '200px 0px',
      }
    );

    if (sentinel && visibleCount < cards.length) {
      observer.observe(sentinel);
    } else if (sentinel) {
      sentinel.remove();
    }
  </script>

  <style>
    .is-hidden {
      display: none;
    }
  </style>
</BlogLayout>