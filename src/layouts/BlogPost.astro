---
import BlogLayout from './Blog.astro';

interface Props {
  frontmatter: {
    title?: string;
    date?: string;
    categories?: string[];
    tags?: string[];
    coverImage?: string;
  };
}

const { frontmatter } = Astro.props;
const {
  title = 'Blogbeitrag',
  date,
  categories = [],
  tags = [],
  coverImage = '',
} = frontmatter ?? {};

const hasCover = typeof coverImage === 'string' && coverImage.trim().length > 0;
const formattedDate = date
  ? new Date(date).toLocaleDateString('de-DE', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric',
    })
  : null;
---
<BlogLayout title={title}>
  <article class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <header class="mb-10 border-b border-gray-200 pb-8">
      <h1 class="mb-4 text-4xl font-bold tracking-tight text-gray-900">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600">
        {formattedDate && <time datetime={date}>{formattedDate}</time>}
        {categories.map((category) => (
          <span class="rounded-full bg-sky-100 px-3 py-1 text-sky-800">{category}</span>
        ))}
      </div>
      {tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2" aria-label="Schlagwörter">
          {tags.map((tag) => (
            <li class="rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-700">#{tag}</li>
          ))}
        </ul>
      )}
      {hasCover && (
        <img
          src={coverImage}
          alt={title}
          class="mt-8 w-full rounded-2xl border border-gray-200 object-cover shadow-sm"
          loading="eager"
          decoding="async"
        />
      )}
    </header>

    <div class="blog-content max-w-none">
      <slot />
    </div>
  </article>
</BlogLayout>
